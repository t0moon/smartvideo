# ========== LLM (brand/storyboard/scenes) ==========
OPENAI_API_KEY=
# OpenAI-compatible API root, usually including /v1 (for example https://example.com/v1)
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
# For some gateways/models (for example gpt-5), function_calling can be more stable.
OPENAI_STRUCTURED_OUTPUT_METHOD=function_calling

# ========== Video generation ==========
# placeholder | openai_videos | http
VIDEO_PROVIDER=placeholder

# Example for HTTP provider:
# VIDEO_PROVIDER=http
# VIDEO_API_BASE_URL=https://your-host.example/v1/video/create
# VIDEO_API_KEY=
# VIDEO_MODEL=veo_3_1-fast-components

# openai_videos (async /v1/videos flow)
# If empty, it falls back to OPENAI_BASE_URL / OPENAI_API_KEY.
VIDEO_API_BASE_URL=
VIDEO_API_KEY=
VIDEO_MODEL=
VIDEO_SIZE=1280x720
VIDEO_POLL_INTERVAL_SEC=3
VIDEO_POLL_TIMEOUT_SEC=600
VIDEO_REQUEST_TIMEOUT_SEC=120
VIDEO_DOWNLOAD_READ_TIMEOUT_SEC=1200

# http provider
# If VIDEO_API_PATH is empty, VIDEO_API_BASE_URL is treated as the full POST endpoint.
VIDEO_API_PATH=
VIDEO_HTTP_TIMEOUT=120

# ========== Audio pipeline (per-shot TTS/SFX + final BGM/mastering) ==========
AUDIO_ENABLE=1
AUDIO_FAILOPEN=1

# Per-shot narration TTS
AUDIO_TTS_ENABLE=1
AUDIO_TTS_PROVIDER=openai
AUDIO_TTS_MODEL=gpt-4o-mini-tts
AUDIO_TTS_VOICE=alloy
AUDIO_TTS_SPEED=1.0
AUDIO_TTS_TIMEOUT_SEC=120
# Optional overrides (fallback uses OPENAI_BASE_URL / OPENAI_API_KEY)
AUDIO_TTS_BASE_URL=
AUDIO_TTS_API_KEY=
AUDIO_NARRATION_GAIN_DB=2

# Per-shot SFX from storyboard_template.shots[].sfx_music.sfx
AUDIO_SFX_ENABLE=1
AUDIO_SFX_GAIN_DB=-2

# Final BGM + mastering
AUDIO_BGM_ENABLE=1
AUDIO_BGM_DUCKING=1
# Optional local music file path. If empty, a simple generated background bed is used.
AUDIO_BGM_PATH=
AUDIO_BGM_GAIN_DB=-24
AUDIO_DUCKING_RATIO=10
AUDIO_TARGET_LUFS=-14

# ========== Project paths ==========
SMARTVIDEO_SKILLS_ROOT=skills
SMARTVIDEO_ARTIFACTS_DIR=outputs
